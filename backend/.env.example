#PostgreSQL connection url
DATABASE_URL=postgresql://user:password@localhost:5432/audyn

# Spotify API (optional — without these, playlists are capped at ~100 tracks)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Auth
# generate your own with
# < openssl rand -hex 32 > on linux
# or
# < python -c "import secrets; print(secrets.token_hex(32))" > on windows
JWT_SECRET=your_long_random_secret_here

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://0.0.0.0:3000

# Cloudinary (avatar uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# OR individual vars:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Optional
# Number of tracks in daily challenge (default: 10)
# Daily challenge
DAILY_TRACK_COUNT=10

# Health check (optional dev feature)
ENABLE_HEALTH_CHECK=false